{
  "name": "@tarmiz/web-glass-toast",
  "version": "1.2.0",
  "description": "Modern glassmorphism toast notifications for React, lightweight UI toast, and notification messages.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json && vite build",
    "lint": "eslint .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "toast",
    "tarmiz",
    "mokhles tarmiz",
    "notification",
    "glassmorphism",
    "ui",
    "react-toast",
    "toast-message",
    "toast-notification",
    "notification-component"
  ],
  "author": "Mokhles Tarmiz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MokhlesTr/web-glass-toast.git"
  },
  "homepage": "https://github.com/MokhlesTr/web-glass-toast#readme",
  "bugs": {
    "url": "https://github.com/MokhlesTr/web-glass-toast/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
